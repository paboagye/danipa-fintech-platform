# Which Spring profile to run the fintech service with
SPRING_PROFILES_ACTIVE=dev

# Use a remote Git repo for the Config Server (instead of the mounted ./config-repo)
# CONFIG_GIT_URI=https://github.com/your-org/your-config-repo.git
# CONFIG_DEFAULT_LABEL=main

# If you secure the Config Server with basic auth:
# CONFIG_USER=configuser
# CONFIG_PASS=configpass
# CONFIG_ENCRYPT_KEY=change-me
