# -------------------
# Global Environment
# -------------------

# Config Server backend: native | git
CONFIG_BACKEND=native

# If using git backend (CONFIG_BACKEND=git)
CONFIG_GIT_URI=
CONFIG_DEFAULT_LABEL=main
CONFIG_USER=
CONFIG_PASS=

# Config Server port (matches docker-compose)
CONFIG_PORT=8088

# Comma-separated locations for native config search
NATIVE_SEARCH_LOCATIONS=file:/config-repo,file:/config-repo/danipa-fintech-service,file:/config-repo/danipa-stripe-service,file:/config-repo/danipa-paypal-service

# -------------------
# Eureka Server
# -------------------
EUREKA_PORT=8761

# -------------------
# Fintech Service
# -------------------
FINTECH_PORT=8080
FINTECH_PROFILE=dev

# -------------------
# Kafka
# -------------------
# External access: localhost:9092
# Internal Docker DNS: kafka:9092
