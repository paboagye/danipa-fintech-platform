# -------------------
# Config Server (native mode for local testing)
# -------------------
CONFIG_BACKEND=native
CONFIG_PORT=8088
NATIVE_SEARCH_LOCATIONS=file:/config-repo,file:/config-repo/danipa-fintech-service,file:/config-repo/danipa-stripe-service,file:/config-repo/danipa-paypal-service

# Git backend unused in dev
CONFIG_GIT_URI=
CONFIG_DEFAULT_LABEL=main
CONFIG_USER=
CONFIG_PASS=

# -------------------
# Eureka
# -------------------
EUREKA_PORT=8761

# -------------------
# Fintech Service
# -------------------
FINTECH_PORT=8080
FINTECH_PROFILE=dev

# -------------------
# Kafka (local Docker)
# -------------------
# Kafka is reachable internally via kafka:9092
